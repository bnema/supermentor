{
  "name": "supermentor",
  "version": "0.3.0",
  "description": "Adaptive mentorship skills and a local browser companion that help coding agents teach humans",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/bnema/supermentor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnema/supermentor.git"
  },
  "keywords": [
    "pi-package",
    "learning",
    "coding-agent",
    "skills",
    "browser",
    "tutoring"
  ],
  "main": ".opencode/plugins/supermentor.js",
  "files": [
    "*.js",
    "*.cjs",
    "*.css",
    "*.html",
    "*.d.ts",
    ".claude-plugin",
    ".opencode",
    "skills",
    "extensions",
    "docs",
    "install",
    "scripts",
    "assets",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test adapters.test.js mentor-client.test.js",
    "smoke": "node scripts/smoke.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0"
  },
  "exports": {
    "./server.cjs": "./server.cjs",
    "./client-shared.js": {
      "types": "./client-shared.d.ts",
      "default": "./client-shared.js"
    },
    "./pi.js": {
      "types": "./pi.d.ts",
      "default": "./pi.js"
    },
    "./opencode.js": {
      "types": "./opencode.d.ts",
      "default": "./opencode.js"
    },
    "./mentor-prompt.js": "./mentor-prompt.js"
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions"
    ]
  }
}
